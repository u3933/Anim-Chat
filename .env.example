# =============================================================
# .env.example - Hiyori Chat configuration template
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.
# =============================================================

# ----- LLM Provider -----
# 'gemini'  : Google Gemini API (default)
# 'openai'  : OpenAI or any OpenAI-compatible API
LLM_PROVIDER=gemini

# ----- Gemini API (used when LLM_PROVIDER=gemini) -----
# API key from Google AI Studio (required for gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (optional, default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ----- OpenAI / OpenAI-compatible (used when LLM_PROVIDER=openai) -----
# Base URL of the OpenAI-compatible endpoint
#   OpenAI official : https://api.openai.com/v1
#   Ollama          : http://localhost:11434/v1
#   LM Studio       : http://localhost:1234/v1
#   llama.cpp       : http://localhost:8080/v1
LLM_BASE_URL=

# API key (leave empty for local LLMs that don't require one)
LLM_API_KEY=

# Model name for the OpenAI-compatible provider (e.g. gpt-4o, llama3, phi3)
LLM_MODEL=

# ----- TTS -----
# TTS provider: 'sbv2' (Style-Bert-VITS2) or 'voicevox' (VOICEVOX)
# (optional, default: sbv2)
TTS_PROVIDER=sbv2

# TTS server URL
#   SBV2     : http://localhost:5000   (default when TTS_PROVIDER=sbv2)
#   VOICEVOX : http://localhost:50021  (default when TTS_PROVIDER=voicevox)
TTS_ENDPOINT=http://localhost:5000

# ----- TTS: Style-Bert-VITS2 settings -----
# Voice model name loaded on the SBV2 server (optional, default: woman001)
TTS_MODEL=woman001

# ----- TTS: VOICEVOX settings -----
# Speaker ID (optional, default: 3)
# Check available IDs at: http://localhost:50021/speakers  (after starting VOICEVOX)
TTS_SPEAKER_ID=3

# Volume 0.0-1.0 (optional, default: 1.0)
TTS_VOLUME=1.0

# ----- App Title (optional, default: Anim Chat) -----
# Title shown in the browser tab and header
# Can also be set via wizard.html
CHAT_TITLE=Anim Chat

# ----- Chat Avatar Persona -----
# System prompt passed to the LLM (optional, default: built-in Hiyori prompt)
# Use \n for line breaks
CHAT_SYSTEM_PROMPT=

# ----- Idle Monologue -----
# Seconds of user inactivity before the avatar speaks a monologue (default: 300 = 5 min)
IDLE_TIMEOUT=300

# ----- Mail -----
# Hours of inactivity before the avatar sends a mail on next launch (default: 8)
MAIL_IDLE_HOURS=8
